# Sift secrets — copy to `.env` and fill in. NEVER commit `.env`.
# These override anything in sift.toml. Nested keys use a double underscore.

# API auth for the Sift web server itself (optional but recommended).
# When set, every /api/* request must send this as a Bearer token or X-Sift-Token.
SIFT_SERVER__API_TOKEN=

# Plex
SIFT_PLEX__TOKEN=

# Radarr
SIFT_RADARR__API_KEY=

# Tautulli
SIFT_TAUTULLI__API_KEY=

# TMDB (v3 API key or v4 bearer token)
SIFT_TMDB__API_KEY=

# Optional: point at a specific config file (defaults to ./sift.toml)
# SIFT_CONFIG=./sift.toml

# Phase 2 (AI): Anthropic key, only needed once the provider layer is enabled.
# ANTHROPIC_API_KEY=
